<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="21dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/widget_large_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="今日课表"
            android:textSize="16sp"
            android:textColor="@color/widget_title_color"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_large_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="第1周"
            android:textSize="12sp"
            android:textColor="@color/widget_week_color" />
    </LinearLayout>

    <!-- 课程1 -->
    <LinearLayout
        android:id="@+id/widget_large_course_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/widget_course_card_bg"
        android:padding="8dp"
        android:layout_marginBottom="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_large_course_1_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/widget_week_color" />

        <TextView
            android:id="@+id/widget_large_course_1_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/widget_title_color"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/widget_large_course_1_room"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/widget_courses_color"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- 课程2 -->
    <LinearLayout
        android:id="@+id/widget_large_course_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/widget_course_card_bg"
        android:padding="8dp"
        android:layout_marginBottom="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_large_course_2_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/widget_week_color" />

        <TextView
            android:id="@+id/widget_large_course_2_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/widget_title_color"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/widget_large_course_2_room"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/widget_courses_color"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- 课程3 -->
    <LinearLayout
        android:id="@+id/widget_large_course_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/widget_course_card_bg"
        android:padding="8dp"
        android:layout_marginBottom="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_large_course_3_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/widget_week_color" />

        <TextView
            android:id="@+id/widget_large_course_3_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/widget_title_color"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/widget_large_course_3_room"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/widget_courses_color"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- 课程4 -->
    <LinearLayout
        android:id="@+id/widget_large_course_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/widget_course_card_bg"
        android:padding="8dp"
        android:layout_marginBottom="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_large_course_4_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/widget_week_color" />

        <TextView
            android:id="@+id/widget_large_course_4_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/widget_title_color"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/widget_large_course_4_room"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/widget_courses_color"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- 课程5 -->
    <LinearLayout
        android:id="@+id/widget_large_course_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/widget_course_card_bg"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_large_course_5_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/widget_week_color" />

        <TextView
            android:id="@+id/widget_large_course_5_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/widget_title_color"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/widget_large_course_5_room"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/widget_courses_color"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- 空课提示 -->
    <TextView
        android:id="@+id/widget_large_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="今天没有课程 🎉"
        android:textSize="14sp"
        android:textColor="@color/widget_courses_color"
        android:visibility="visible" />

</LinearLayout>
